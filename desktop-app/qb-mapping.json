{
  "_comment": "Mapping Toast Excel Report → QB Sale Receipt cho từng store",
  "_instructions": [
    "sales_category_map: Toast 'Sales category' → QB Item name",
    "  Key = tên category trong Excel (Sales category summary sheet)",
    "  Value = tên Item trong QB. null = bỏ qua",
    "",
    "payment_map: Toast payment type/sub type → QB Item name (amount sẽ là SỐ ÂM)",
    "  Key = 'Payment type' hoặc 'Payment sub type' trong Excel",
    "  Value = tên Item trong QB",
    "",
    "fixed_items: Các dòng cố định (discounts, tax, tips...)",
    "  toast_source = sheet/column trong Excel để lấy số liệu",
    "",
    "Để xem Item List trong QB: python qb-sync.py --list-items --store 'The Rim'"
  ],

  "global": {
    "qbxml_version": "13.0",
    "app_name": "Toast Report Sync"
  },

  "stores": {
    "The Rim": {
      "qbw_match": "jht ventures",
      "password": "pass1",
      "toast_location": "The Rim",
      "customer_name": "Toast",
      "sale_no_prefix": "",
      "csv_map": "jht.csv"
    },

    "Stockton": {
      "qbw_match": "rawstockton",
      "password": "pass2",
      "toast_location": "Stockton",
      "customer_name": "Toasttab",
      "sale_no_prefix": "",
      "csv_map": "raw.csv",
      "_note_toast_filename_pattern": "Optional. Use {date} placeholder, e.g. 'SalesSummary_{date}_{date}.xlsx'",
      "additional_sale_receipts": [
        {
          "name": "Uber",
          "customer_name": "Uber",
          "ref_prefix": "UE",
          "file_name": "UberSale.csv",
          "csv_map": "uber_raw.csv"
        },
        {
          "name": "DoorDash",
          "customer_name": "DoorDash",
          "ref_prefix": "DD",
          "file_name": "DoordashSale.csv",
          "csv_map": "doordash_raw.csv"
        },
        {
          "name": "Grubhub",
          "customer_name": "Grubhub",
          "ref_prefix": "GH",
          "file_name": "GrubhubSale.csv",
          "csv_map": "grubhub_raw.csv"
        }
      ]
    },

    "Stone Oak": {
      "qbw_match": "bakudan ramen",
      "password": "pass1",
      "toast_location": "Stone Oak",
      "customer_name": "Toasttab",
      "sale_no_prefix": "",
      "csv_map": "stone_oak.csv"
    },

    "Bandera": {
      "qbw_match": "bakudan bp",
      "password": "pass1",
      "toast_location": "Bandera",
      "customer_name": "Toast",
      "sale_no_prefix": "",
      "csv_map": "bandera.csv"
    },

    "Copper": {
      "qbw_match": "coppers",
      "password": "pass1",
      "toast_locations": ["WA1", "WA2", "WA3"],
      "sub_stores": {
        "C1": {"toast_location": "WA1", "customer_name": "C1", "class_name": "C1"},
        "C2": {"toast_location": "WA2", "customer_name": "C2", "class_name": "C2"},
        "C3": {"toast_location": "WA3", "customer_name": "C3", "class_name": "C3"}
      },
      "sale_no_prefix": "",
      "csv_map": "copper.csv"
    },

    "IFT": {
      "qbw_match": "ift",
      "password": "pass3",
      "toast_location": "IFT",
      "customer_name": "_TODO",
      "sale_no_prefix": "",
      "csv_map": "ift.csv",
      "_note": "IFT uses Squareup, not Toast. Mapping TBD"
    },

    "Jinya": {
      "qbw_match": "jinya",
      "password": "pass1",
      "toast_location": "Jinya",
      "customer_name": "_TODO",
      "sale_no_prefix": "",
      "csv_map": "jinya.csv",
      "_note": "Mapping TBD - need to check QB items and customers"
    }
  }
}
