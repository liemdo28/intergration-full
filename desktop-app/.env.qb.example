# QuickBooks Desktop executable
QB_EXE_PATH=C:\Program Files\Intuit\QuickBooks Enterprise Solutions 24.0\QBWEnterprise.exe

# Optional default folder used when scanning for .qbw files
QB_COMPANY_DIR=D:\QB

# Password slots referenced by qb-mapping.json store configs
QB_PASSWORD1=
QB_PASSWORD2=
QB_PASSWORD3=

# Delete policy override
# Leave this unset or set to 0 for normal operation.
# Only set to 1 during an approved maintenance window.
ALLOW_LIVE_DELETE=0
DELETE_APPROVER=
