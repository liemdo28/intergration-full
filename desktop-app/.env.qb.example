# QuickBooks Passwords
# Rename this file to .env.qb and fill in your actual passwords
#
# QB_PASSWORD1 = password for stores using pass1 (The Rim, Stone Oak, Bandera, Copper, Jinya)
# QB_PASSWORD2 = password for stores using pass2 (Stockton)
# QB_PASSWORD3 = password for stores using pass3 (IFT)

QB_PASSWORD1=YOUR_PASSWORD_1_HERE
QB_PASSWORD2=YOUR_PASSWORD_2_HERE
QB_PASSWORD3=YOUR_PASSWORD_3_HERE
